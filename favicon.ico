<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>兔兔丸机</title>
    
    <!-- 引入 Dexie.js 封装 IndexedDB -->
    <script src="https://unpkg.com/dexie@3.2.4/dist/dexie.js"></script>

    <link rel="stylesheet" href="./app.css">


    <meta name="theme-color" content="#FFF0F5">
    <meta name="application-name" content="兔兔丸机">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="兔兔丸机">
    <link rel="manifest" href="./manifest.json">
    <link rel="apple-touch-icon" href="./assets/icon-192.png">

</head>
<body class="tutuwan-app-body activation-locked" data-app-version="v0.0.6-complete-changelog">
<div id="tutuwan-activation-gate" class="tutuwan-activation-gate" aria-live="polite">
    <div class="tutuwan-activation-card">
        <div class="tutuwan-activation-brand">
            <img src="./assets/icon-192.png" alt="兔兔丸机图标" class="tutuwan-activation-icon">
            <div>
                <div class="tutuwan-activation-title">兔兔丸机激活验证</div>
                <div class="tutuwan-activation-subtitle">此设备需要激活后才能进入应用</div>
            </div>
        </div>
        <div class="tutuwan-device-box">
            <label>当前设备码</label>
            <div class="tutuwan-device-row">
                <code id="tutuwan-device-code">正在生成设备码</code>
                <button id="tutuwan-copy-device" type="button">复制</button>
            </div>
        </div>
        <label class="tutuwan-activation-label" for="tutuwan-activation-code">激活码</label>
        <input id="tutuwan-activation-code" class="tutuwan-activation-input" autocomplete="one-time-code" placeholder="Tutuwan-xxxx-xxxx-xxxx">
        <button id="tutuwan-activate-btn" class="tutuwan-activation-button" type="button">验证并进入</button>
        <div id="tutuwan-activation-message" class="tutuwan-activation-message"></div>
        <div class="tutuwan-activation-hint">
            激活码由生成器根据设备码生成。未完成验证时，应用内容会保持锁定。
        </div>
    </div>
</div>

<video id="theme-wallpaper-video" autoplay muted loop playsinline></video>

<div class="mobile-container">

    <!-- Top Wide Widget -->
    <div class="top-widget-container">
        <div class="top-widget">
            <img src="https://picsum.photos/id/1025/150/150" class="avatar" id="avatar-img" alt="头像">
            <div class="bubble-dot-1"></div>
            <div class="bubble-dot-2"></div>
            <div class="speech-bubble editable-text" id="text-speech">ovo</div>
            
            <div class="top-row">
                <div class="flex" style="gap: 6px;">
                    <div class="pill editable-text" id="text-temp">19°C</div>
                    <div class="pill" id="battery-pill-text">70%</div>
                </div>
                <div class="flex top-right-icons items-center" style="gap: 6px;">
                    <div class="top-right-icon-bg"><svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><circle cx="12" cy="20" r="1.5" stroke="none" fill="currentColor"></circle></svg></div>
                    <div class="top-right-icon-bg">
                        <svg viewBox="0 0 24 24">
                            <circle cx="12" cy="9" r="2" stroke="none" fill="currentColor"></circle>
                            <path d="M8 5a6 6 0 0 0 0 8"></path>
                            <path d="M16 5a6 6 0 0 1 0 8"></path>
                            <path d="M5 2a10 10 0 0 0 0 14"></path>
                            <path d="M19 2a10 10 0 0 1 0 14"></path>
                            <line x1="12" y1="11" x2="12" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
                        </svg>
                    </div>
                    <div class="top-right-icon-bg"><svg viewBox="0 0 24 24"><polyline points="6.5 6.5 17.5 17.5 12 23 12 1 17.5 6.5 6.5 17.5"></polyline></svg></div>
                </div>
            </div>
            
            <div class="user-name-row">
                <span class="editable-text" id="text-username" style="font-size: 14px; color: var(--gray-text); font-weight: 600;">点击编辑昵称</span>
                <div style="font-size: 10px; padding: 2px 10px; background: #F6EEF1; color: var(--pink-dark); border-radius: 12px; font-weight: 500;">修改</div>
            </div>
            
            <div class="dashed-divider"></div>
            
            <div class="flex justify-between items-center px-2">
                <div class="bottom-action" id="home-profile-action" role="button" tabindex="0"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> 修改資料</div>
                <div class="bottom-action" id="home-level-action" role="button" tabindex="0"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg> 我的等级</div>
                <div class="bottom-action" id="home-save-photo-action" role="button" tabindex="0"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg> 存為照片</div>
            </div>
        </div>
    </div>

    <!-- 坚不可摧的绝对方块基底网格 -->
    <div class="grid-container">
        
        <!-- Left 2x2 Widget -->
        <div class="cell-2x2">
            <div class="cell-content-2x2 left-widget-card">
                <div class="flex justify-between items-center">
                    <div class="flex items-center" style="gap: 4px;">
                        <span class="editable-text" id="text-left-title" style="font-size: 12px; font-weight: 600; color: var(--gray-text);">福熊兒</span>
                        <svg viewBox="0 0 24 24" width="12" height="12" stroke="#F4A6C3" fill="none" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    </div>
                    <div style="background: var(--pink-light); border-radius: 50%; width: 16px; height: 16px; display: flex; justify-content: center; align-items: center;">
                        <svg viewBox="0 0 24 24" width="10" height="10" stroke="#FFF" stroke-width="3" fill="none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </div>
                </div>
                
                <div style="font-size: 9px; color: var(--pink-text); text-align: center;">00:14 上午</div>
                
                <div class="lw-image-row">
                    <svg id="lw-prev-btn" class="editable-text" viewBox="0 0 24 24" width="14" height="14" stroke="#E3C9D3" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M14 8l-4 4 4 4"/></svg>
                    <div class="lw-img-wrap">
                        <img src="https://picsum.photos/id/1062/200/200" id="left-widget-img" alt="photo">
                    </div>
                    <svg id="lw-next-btn" class="editable-text" viewBox="0 0 24 24" width="14" height="14" stroke="#E3C9D3" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M10 8l4 4-4 4"/></svg>
                </div>
                
                <div class="flex justify-center items-center" style="gap: 4px; font-size: 9px; color: var(--pink-dark); margin-bottom: 6px; font-weight: 500;">
                    <svg viewBox="0 0 24 24" width="11" height="11" stroke="currentColor" fill="none" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <span class="editable-text" id="text-left-sub">Kitty向您提出了好友申请</span>
                </div>
                
                <div class="flex" style="gap: 6px;">
                    <div id="left-widget-accept" role="button" tabindex="0" style="flex: 1; background: var(--pink-light); color: var(--pink-dark); text-align: center; font-size: 11px; font-weight: 600; padding: 6px 0; border-radius: 10px; cursor:pointer;">同意</div>
                    <div id="left-widget-reject" role="button" tabindex="0" style="flex: 1; background: #F6EEF1; color: #9A8992; text-align: center; font-size: 11px; font-weight: 600; padding: 6px 0; border-radius: 10px; cursor:pointer;">拒绝</div>
                </div>
            </div>
        </div>

        <!-- Row 1 Apps -->
        <div class="cell-1x1" id="btn-music"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg></div><div class="app-name">音乐</div></div>
        <div class="cell-1x1" id="btn-chat">
            <div class="cell-content-1x1">
                <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-4.1-.98 1 1 0 0 0-.84.1l-2.7 1.4a.6.6 0 0 1-.86-.74l1.3-2.9a1 1 0 0 0-.1-.94A9 9 0 1 1 21 12z"></path></svg>
            </div>
            <div class="app-name">聊天</div>
        </div>

        <!-- Row 2 Apps -->
        <div class="cell-1x1" id="btn-twitter"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><line x1="4" y1="4" x2="20" y2="20"></line><line x1="20" y1="4" x2="4" y2="20"></line></svg></div><div class="app-name">推特</div></div>
        <div class="cell-1x1" id="btn-shop"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></div><div class="app-name">购物</div></div>

        <!-- Row 3 Apps -->
        <div class="cell-1x1" id="btn-food-delivery"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><path d="M4 14.5A2.5 2.5 0 0 0 6.5 17h11a2.5 2.5 0 0 0 2.5-2.5v-2H4v2z"></path><path d="M12 4a7 7 0 0 0-7 7h14a7 7 0 0 0-7-7z"></path><line x1="12" y1="2" x2="12" y2="4"></line></svg></div><div class="app-name">外卖</div></div>
        <div class="cell-1x1" id="btn-peep-check"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"></circle><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"></path></svg></div><div class="app-name">查岗</div></div>

        <!-- Right 2x2 Widget -->
        <div class="cell-2x2">
            <div class="cell-content-2x2 right-widget-border">
                <div class="right-widget-inner">
                    <div class="flex justify-between items-center" style="height: 14px; margin-bottom: 6px; color: var(--pink-dark);">
                        <div class="flex items-center" style="gap: 4px; font-size: 10px; font-weight: 600;">
                            <span id="battery-widget-text">70%</span>
                            <div style="width: 18px; height: 10px; border: 1.5px solid currentColor; border-radius: 4px; padding: 1px; display: flex; align-items: center;">
                                <div id="battery-widget-fill" style="height: 100%; width: 70%; background: currentColor; border-radius: 1.5px; transition: width 0.3s ease;"></div>
                            </div>
                        </div>
                        <div class="flex items-center" style="gap: 8px;">
                            <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" fill="none" stroke-width="2.5">
                                <path d="M5 12.55a11 11 0 0 1 14.08 0"></path>
                                <path d="M1.42 9a16 16 0 0 1 21.16 0"></path>
                                <path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path>
                                <circle cx="12" cy="20" r="1.5" stroke="none" fill="currentColor"></circle>
                            </svg>
                            <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" fill="none" stroke-width="2.5">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                            </svg>
                        </div>
                    </div>
                    <div style="position: absolute; top: 28px; bottom: 8px; left: 8px; right: 8px; border-radius: 12px; overflow: hidden;">
                        <img src="https://picsum.photos/id/237/200/200" id="right-widget-img" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.85; cursor: pointer;" alt="dog">
                        <div style="position: absolute; top: 6px; right: 6px; background: rgba(255,255,255,0.95); padding: 3px 6px; border-radius: 12px; font-size: 9px; color: var(--pink-dark); font-weight: 600;">
                            <span class="editable-text" id="text-right-tag">呆呆嘟</span>
                            <div style="position: absolute; bottom: -3px; left: 8px; width: 6px; height: 6px; background: rgba(255,255,255,0.95); border-radius: 50%; pointer-events: none;"></div>
                        </div>
                    </div>
                </div>
                
                <div class="paw-circle">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="var(--pink-dark)">
                        <circle cx="5.5" cy="10.5" r="2.2"/><circle cx="9.5" cy="6.5" r="2.5"/>
                        <circle cx="14.5" cy="6.5" r="2.5"/><circle cx="18.5" cy="10.5" r="2.2"/>
                        <path d="M12 12c-2.5 0-5.5 1.5-6.5 4.5-.5 1.5.5 3.5 2.5 4.5 1.5.5 3-.5 4-1.5 1 1 2.5 2 4 1.5 2-.5 3-2.5 2.5-4.5C17.5 13.5 14.5 12 12 12z"/>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Row 4 Apps -->
        <div class="cell-1x1" id="btn-peep-room"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg></div><div class="app-name">窥探</div></div>
        <div class="cell-1x1" id="btn-couple-space"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg></div><div class="app-name">情侣空间</div></div>

    </div>

    <!-- Search Bar -->
    <div class="search-container">
        <div class="search-bar" id="desktop-search-bar" role="button" tabindex="0" aria-label="搜索应用和联系人">
            <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" fill="none" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            搜索
        </div>
    </div>

    <!-- 底部 Dock -->
    <div class="dock-wrapper">
        <div class="dock-container">
            <div class="cell-1x1" id="btn-desktop-messages"><div class="cell-content-1x1 desktop-message-icon"><svg viewBox="0 0 24 24"><path d="M12 4C7.58 4 4 7.1 4 10.92c0 2.18 1.17 4.12 3 5.39l-.72 2.43c-.12.41.31.76.68.55l2.73-1.53c.73.18 1.5.28 2.31.28 4.42 0 8-3.1 8-6.92S16.42 4 12 4Z"></path></svg></div></div>
            <div class="cell-1x1" id="btn-worldbook"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg></div></div>
            <div class="cell-1x1" id="btn-theme"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><path d="M21 3l-6 6"></path><path d="M21 3l-2 2"></path><path d="M3 21l6-6"></path><path d="M3 21l2-2"></path><path d="M10 14l4-4"></path><path d="M19 8l-4-4"></path></svg></div></div>
            <!-- 设置应用按钮 -->
            <div class="cell-1x1" id="btn-settings"><div class="cell-content-1x1"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg></div></div>
        </div>
    </div>

    <!-- 优化版设置面板叠加层 -->
    <div id="settings-page" class="settings-page-overlay">
        <div class="settings-header">
            <svg id="close-settings-btn" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2.5" style="margin-right: 12px; cursor: pointer;">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <span>设置中心</span>
        </div>
        <div class="settings-content">
            <!-- 聊天 API -->
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    聊天 API
                    <span class="help-icon" onclick="openHelpModal('chat')">?</span>
                </h4>
                <div class="settings-row-horizontal">
                    <select class="settings-select" id="chat-preset-select" style="flex: 1;">
                        <option value="default">默认预设</option>
                    </select>
                    <button class="icon-btn" id="chat-preset-save" title="保存预设"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg></button>
                    <button class="icon-btn" id="chat-preset-delete" title="删除预设" style="color: #E57373; background: #FFECEC; border-color: #FFE0E0;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></button>
                </div>
                <div class="settings-row">
                    <span class="settings-label">接口网址（OpenAI 兼容基础地址，填写到 /v1）</span>
                    <input type="text" id="chat-url-input" class="settings-input" placeholder="https://api.openai.com/v1">
                </div>
                <div class="settings-row">
                    <span class="settings-label">API Key</span>
                    <input type="password" id="chat-key-input" class="settings-input" placeholder="sk-...">
                </div>
                <div class="settings-row">
                    <span class="settings-label">模型选择</span>
                    <div style="display: flex; gap: 10px;">
                        <input type="text" id="chat-model-input" class="settings-input" value="gpt-3.5-turbo" placeholder="点击后可直接输入模型名，如 gpt-4o" style="flex: 1;">
                        <datalist id="chat-model-list"></datalist>
                        <button class="icon-btn" id="chat-fetch-models-btn" title="拉取模型"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="8 17 12 21 16 17"></polyline><line x1="12" y1="12" x2="12" y2="21"></line><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"></path></svg></button>
                    </div>
                </div>
                <div class="settings-row" style="margin-top: 10px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                        <span class="settings-label">温度 (Temperature)</span>
                        <span class="settings-label" id="temp-val-display" style="color: var(--pink-dark); font-size: 14px;">0.7</span>
                    </div>
                    <input type="range" id="chat-temperature" min="0" max="2" step="0.1" value="0.7">
                </div>
                <div class="settings-row" style="margin-top: 10px;">
                    <span class="settings-label">上下文数量</span>
                    <input type="number" id="chat-context-input" class="settings-input" value="30" min="0">
                </div>
            </div>

            <!-- 语音 API -->
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>
                    语音 API
                    <span class="help-icon" onclick="openHelpModal('voice')">?</span>
                </h4>
                <div class="settings-row-horizontal">
                    <select class="settings-select" id="voice-preset-select" style="flex: 1;">
                        <option value="default">默认预设</option>
                    </select>
                    <button class="icon-btn" id="voice-preset-save" title="保存预设"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg></button>
                    <button class="icon-btn" id="voice-preset-delete" title="删除预设" style="color: #E57373; background: #FFECEC; border-color: #FFE0E0;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></button>
                </div>
                <div class="settings-row">
                    <span class="settings-label">接口网址（MiniMax 官方同步语音：/v1/t2a_v2）</span>
                    <input type="text" id="voice-url-input" class="settings-input" placeholder="https://api.minimax.io/v1">
                </div>
                <div class="settings-row">
                    <span class="settings-label">API Key</span>
                    <input type="password" id="voice-key-input" class="settings-input" placeholder="sk-...">
                </div>
                <div class="settings-row">
                    <span class="settings-label">GROUP ID</span>
                    <input type="text" id="voice-group-input" class="settings-input" placeholder="输入 Group ID，如 anime_female">
                </div>
                <div class="settings-row">
                    <span class="settings-label">VOICE ID</span>
                    <div style="display: flex; gap: 10px;">
                        <input type="text" id="voice-id-input" class="settings-input" placeholder="输入 Voice ID，如 tutumaru_01" style="flex: 1;">
                        <button class="icon-btn" id="voice-test-btn" title="试听声音"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></button>
                    </div>
                </div>
            </div>

            <!-- 数据管理 -->
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
                    数据管理
                    <span class="help-icon" onclick="openHelpModal('github')">?</span>
                </h4>
                
                <!-- Github 配置区域 -->
                <div style="background: #FFF8FA; border: 1.5px dashed #FCE8EF; border-radius: 16px; padding: 14px; margin-bottom: 16px;">
                    <div class="settings-row" style="margin-bottom: 10px;">
                        <span class="settings-label">GitHub Token</span>
                        <input type="password" id="github-token-input" class="settings-input" placeholder="ghp_xxxxxxxxxxxx" style="background: #FFF;">
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <div class="settings-row" style="flex: 1; margin-bottom: 0;">
                            <span class="settings-label">GitHub 用户名</span>
                            <input type="text" id="github-user-input" class="settings-input" placeholder="Username" style="background: #FFF;">
                        </div>
                        <div class="settings-row" style="flex: 1; margin-bottom: 0;">
                            <span class="settings-label">存储仓库名</span>
                            <input type="text" id="github-repo-input" class="settings-input" placeholder="Repo Name" style="background: #FFF;">
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <button class="action-btn primary" id="github-backup-btn" style="grid-column: span 2;">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align: middle; margin-right: 4px; margin-top: -2px;"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                        一键 Github 备份
                    </button>
                    <button class="action-btn" id="export-data-btn">导出数据</button>
                    <button class="action-btn" id="export-batch-btn">批量导出</button>
                    <button class="action-btn" id="import-data-btn">导入数据</button>
                    <button class="action-btn" id="import-batch-btn">批量导入</button>
                    <button class="action-btn danger" id="clear-data-btn" style="grid-column: span 2;">清除所有数据</button>
                </div>
            </div>

            <!-- 免责声明 (换行分段) -->
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 7.5v5.5"></path><path d="M12 16.5h.01"></path></svg>
                    免责声明
                </h4>
                <div style="font-size: 11px; color: #888; line-height: 1.65; text-align: justify; padding: 4px; letter-spacing: 0.3px;">
                    <p>本应用程序（含所有相关服务、功能及提供的数据）仅作为展示与测试用途。开发者不对用户所填写、提交、处理或存储的任何数据的安全性、准确性及可靠性作任何形式的保证。</p>
                    <p style="margin-top: 6px;">您在使用过程中连接的第三方 API（包括但不限于聊天API及语音API）所产生的任何费用、数据泄露及滥用风险，均由使用者自行承担。本软件不对因使用本程序或其衍生物所导致的直接或间接损失负任何法律责任。</p>
                    <p style="margin-top: 6px;">用户须遵守所在国家和地区的法律法规，禁止使用本程序进行任何违法违规操作。由于本程序产生的内容均由调用的第三方人工智能模型提供，程序本身不涉及任何核心数据或算法的存储与运算，不对其生成的内容合法性、道德性及正确性负责。</p>
                    <p style="margin-top: 6px;">若有任何违反政策的风险由使用者自行规避。继续使用本应用即表示您已充分阅读、理解并完全同意本免责声明的全部条款及潜在风险。</p>
                </div>
            </div>

            <!-- 版本号 -->
            <div style="text-align: center; color: #C2B6BC; font-size: 11px; margin-top: 24px; font-weight: 500;">
                版本 0.0.6 · 完整完善版
            </div>
        </div>
        <input type="file" id="settings-import-file" class="hidden-file-input" accept="application/json,.json">
        <input type="file" id="settings-batch-import-file" class="hidden-file-input" accept="application/json,.json" multiple>
        
        <!-- 全局吐司提示 -->
        <div id="toast-msg" style="position: absolute; top: 80px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.7); color: #FFF; padding: 12px 20px; border-radius: 20px; font-size: 13px; z-index: 10001; display: none; transition: opacity 0.3s; opacity: 0; pointer-events: none; white-space: nowrap; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
            兔兔丸提示：语音测试成功~
        </div>
    </div>

    <!-- 世界书应用：底部 Dock 第二个图标入口 -->
    <div id="worldbook-page" class="settings-page-overlay worldbook-page-overlay">
        <div class="settings-header">
            <svg id="worldbook-back-btn" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2.5" style="margin-right: 12px; cursor: pointer;">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <span id="worldbook-header-title">世界书</span>
            <div class="worldbook-header-actions">
                <button class="worldbook-icon-btn" id="worldbook-add-btn" title="添加" aria-label="添加">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </button>
                <button class="worldbook-icon-btn" id="worldbook-manage-btn" title="管理" aria-label="管理">
                    <svg viewBox="0 0 24 24"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line><circle cx="8" cy="6" r="2"></circle><circle cx="16" cy="12" r="2"></circle><circle cx="10" cy="18" r="2"></circle></svg>
                </button>
            </div>
        </div>

        <div id="worldbook-group-view" class="settings-content">
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                    世界书分组
                </h4>
                <p class="worldbook-subtitle">点击右上角添加图标创建世界书；点击分组进入条目页，管理图标可切换删除状态。</p>
                <div id="worldbook-group-list" class="worldbook-list"></div>
                <div id="worldbook-group-empty" class="worldbook-empty">暂无世界书分组<br>点击右上角添加图标创建第一个世界书</div>
            </div>
        </div>

        <div id="worldbook-entry-view" class="settings-content" style="display: none;">
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="8" y1="13" x2="16" y2="13"></line><line x1="8" y1="17" x2="16" y2="17"></line></svg>
                    条目列表
                </h4>
                <p class="worldbook-subtitle">点击右上角添加图标进入条目页；条目名可不填，保存时默认命名为「条目」。</p>
                <div id="worldbook-entry-list" class="worldbook-list"></div>
                <div id="worldbook-entry-empty" class="worldbook-empty">暂无条目<br>点击右上角添加图标新建世界书条目</div>
            </div>
        </div>

        <div id="worldbook-editor-view" class="settings-content" style="display: none;">
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>
                    条目设置
                </h4>
                <div class="settings-row">
                    <span class="settings-label">条目名</span>
                    <input type="text" id="worldbook-entry-name" class="settings-input" placeholder="可不填，默认「条目」">
                </div>
                <div class="settings-row">
                    <span class="settings-label">世界书类型</span>
                    <div class="worldbook-segment" id="worldbook-entry-scope">
                        <button type="button" data-value="global" class="active">全局世界书</button>
                        <button type="button" data-value="character">角色世界书</button>
                    </div>
                </div>
                <div class="settings-row">
                    <span class="settings-label">生效方式</span>
                    <div class="worldbook-segment" id="worldbook-entry-trigger">
                        <button type="button" data-value="always" class="active">始终生效</button>
                        <button type="button" data-value="keyword">关键词生效</button>
                    </div>
                </div>
                <div class="settings-row" id="worldbook-keyword-wrap" style="display: none;">
                    <span class="settings-label">关键词</span>
                    <input type="text" id="worldbook-entry-keywords" class="settings-input worldbook-keyword-input" placeholder="多个关键词用逗号或换行分隔">
                </div>
                <div class="settings-row">
                    <span class="settings-label">注入位置</span>
                    <div class="worldbook-segment three" id="worldbook-entry-position">
                        <button type="button" data-value="before" class="active">前</button>
                        <button type="button" data-value="middle">中</button>
                        <button type="button" data-value="after">后</button>
                    </div>
                    <div id="worldbook-position-help" class="worldbook-position-help">前：API 以正文为基础思考输出</div>
                </div>
                <div class="settings-row">
                    <span class="settings-label">条目正文</span>
                    <textarea id="worldbook-entry-content" class="worldbook-textarea" placeholder="输入世界书条目正文..."></textarea>
                </div>
                <div class="worldbook-editor-actions">
                    <button class="action-btn" id="worldbook-cancel-entry-btn">取消</button>
                    <button class="action-btn primary" id="worldbook-save-entry-btn">保存条目</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 情侣空间应用：联系人联动 / 动态 / 相册 / 日历 / 信箱 / 问答 / 心情 -->
    <div id="couple-app-page" aria-hidden="true">
        <div class="couple-bg-soft" id="couple-bg-soft"></div>
        <div class="couple-app-shell">
            <header class="couple-header">
                <button class="couple-icon-btn" id="couple-close-btn" type="button" aria-label="返回"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
                <div class="couple-title-stack">
                    <div class="couple-title" id="couple-header-title">情侣空间</div>
                    <div class="couple-subtitle" id="couple-header-subtitle">选择联系人建立空间</div>
                </div>
                <button class="couple-icon-btn" id="couple-refresh-btn" type="button" aria-label="刷新"><svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 0 1-15.5 6.2"></path><path d="M3 12A9 9 0 0 1 18.5 5.8"></path><polyline points="18 2 18.5 5.8 14.8 6.3"></polyline><polyline points="6 22 5.5 18.2 9.2 17.7"></polyline></svg></button>
                <button class="couple-icon-btn" id="couple-settings-btn" type="button" aria-label="设置"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9c.14.31.23.65.23 1H21a2 2 0 0 1 0 4h-1.37c0 .35-.09.69-.23 1z"></path></svg></button>
            </header>

            <main class="couple-selector-view" id="couple-selector-view">
                <div class="couple-selector-hero">
                    <div class="couple-kicker">PRIVATE SPACE</div>
                    <h2>选择一个 char，建立独立情侣空间</h2>
                    <p>情侣空间会读取联系人设定、user 设定、共同聊天记忆和世界书，生成符合人设的动态、评论、信件、提问与心情记录。</p>
                </div>
                <div id="couple-selector-list" class="couple-selector-list"></div>
            </main>

            <main class="couple-dashboard-view" id="couple-dashboard-view">
                <section class="couple-top-card" id="couple-top-card">
                    <div class="couple-pair-row">
                        <div class="couple-avatar-pair">
                            <img id="couple-user-avatar" alt="user">
                            <img id="couple-char-avatar" alt="char">
                        </div>
                        <div class="couple-pair-meta">
                            <div id="couple-pair-name" class="couple-pair-name">user 与 char</div>
                            <div id="couple-pair-note" class="couple-pair-note">恋爱记录正在同步</div>
                        </div>
                    </div>
                    <button class="couple-days-card" id="couple-days-card" type="button">
                        <span>在一起</span>
                        <b id="couple-days-num">1</b>
                        <span id="couple-start-date-label">点击修改纪念日</span>
                    </button>
                    <input type="date" id="couple-start-date-input" class="couple-hidden-date">
                </section>

                <nav class="couple-tabbar" id="couple-tabbar">
                    <button class="active" type="button" data-couple-tab="moments">动态</button>
                    <button type="button" data-couple-tab="album">相册</button>
                    <button type="button" data-couple-tab="calendar">日历</button>
                    <button type="button" data-couple-tab="letters">信箱</button>
                    <button type="button" data-couple-tab="questions">问答</button>
                    <button type="button" data-couple-tab="moods">心情</button>
                </nav>

                <section class="couple-tab-content active" id="couple-tab-moments">
                    <div class="couple-section-head"><div><h3>恋爱动态</h3><p>可发布悄悄话，char 会按人设评论或主动发动态</p></div><button class="couple-small-btn" id="couple-ai-post-btn" type="button">生成动态</button></div>
                    <div id="couple-moments-list" class="couple-feed-list"></div>
                </section>
                <section class="couple-tab-content" id="couple-tab-album">
                    <div class="couple-section-head"><div><h3>共同相册</h3><p>保存本地上传的照片，可点开预览</p></div><button class="couple-small-btn" id="couple-album-upload-btn" type="button">上传照片</button></div>
                    <input type="file" id="couple-album-input" class="couple-hidden-file" accept="image/*" multiple>
                    <div id="couple-album-grid" class="couple-album-grid"></div>
                </section>
                <section class="couple-tab-content" id="couple-tab-calendar">
                    <div class="couple-cal-header">
                        <button class="couple-icon-btn mini" type="button" data-couple-month="-1"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
                        <div id="couple-calendar-title" class="couple-calendar-title">本月</div>
                        <button class="couple-icon-btn mini" type="button" data-couple-month="1"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
                    </div>
                    <div class="couple-week-row"><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span><span>日</span></div>
                    <div id="couple-calendar-grid" class="couple-calendar-grid"></div>
                    <div class="couple-calendar-legend"><span class="period">经期</span><span class="predict">预测</span><span class="ovulation">排卵</span><span class="date">约会</span><span class="special">纪念</span></div>
                </section>
                <section class="couple-tab-content" id="couple-tab-letters">
                    <div class="couple-section-head"><div><h3>秘密信箱</h3><p>写长信、保存草稿、索要 char 回信</p></div><button class="couple-small-btn" id="couple-ask-letter-btn" type="button">索要来信</button></div>
                    <div id="couple-letters-list" class="couple-letter-list"></div>
                </section>
                <section class="couple-tab-content" id="couple-tab-questions">
                    <div class="couple-section-head"><div><h3>每日一问</h3><p>互相提问，回答会同步进情侣空间记忆</p></div><button class="couple-small-btn" id="couple-char-question-btn" type="button">让TA提问</button></div>
                    <div id="couple-questions-list" class="couple-question-list"></div>
                </section>
                <section class="couple-tab-content" id="couple-tab-moods">
                    <div class="couple-section-head"><div><h3>心情记录</h3><p>记录双方状态，char 可模拟离线生活心情</p></div><button class="couple-small-btn" id="couple-ai-mood-btn" type="button">生成TA心情</button></div>
                    <div id="couple-moods-list" class="couple-mood-list"></div>
                </section>
            </main>

            <button id="couple-fab" class="couple-fab" type="button" aria-label="新增"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg></button>
        </div>

        <div id="couple-compose-modal" class="couple-modal" aria-hidden="true">
            <div class="couple-modal-card">
                <div class="couple-modal-title" id="couple-compose-title">发布</div>
                <input id="couple-compose-title-input" class="couple-input" placeholder="标题，可留空">
                <textarea id="couple-compose-text" class="couple-textarea" placeholder="写下内容"></textarea>
                <div class="couple-modal-actions"><button class="couple-ghost-btn" id="couple-compose-cancel" type="button">取消</button><button class="couple-primary-btn" id="couple-compose-submit" type="button">保存</button></div>
            </div>
        </div>

        <div id="couple-period-modal" class="couple-modal" aria-hidden="true">
            <div class="couple-modal-card compact">
                <div class="couple-modal-title" id="couple-period-title">标记日期</div>
                <div class="couple-period-actions">
                    <button type="button" data-couple-period="period">经期</button>
                    <button type="button" data-couple-period="predict">预测</button>
                    <button type="button" data-couple-period="ovulation">排卵</button>
                    <button type="button" data-couple-period="date">约会</button>
                    <button type="button" data-couple-period="special">纪念</button>
                    <button type="button" data-couple-period="">清除</button>
                </div>
                <div class="couple-modal-actions"><button class="couple-ghost-btn" id="couple-period-cancel" type="button">关闭</button></div>
            </div>
        </div>

        <div id="couple-mood-modal" class="couple-modal" aria-hidden="true">
            <div class="couple-modal-card">
                <div class="couple-modal-title">记录心情</div>
                <div id="couple-mood-options" class="couple-mood-options"></div>
                <textarea id="couple-mood-text" class="couple-textarea small" placeholder="补一句今天的状态，可留空"></textarea>
                <div class="couple-modal-actions"><button class="couple-ghost-btn" id="couple-mood-cancel" type="button">取消</button><button class="couple-primary-btn" id="couple-mood-submit" type="button">保存</button></div>
            </div>
        </div>

        <div id="couple-settings-modal" class="couple-modal" aria-hidden="true">
            <div class="couple-modal-card settings">
                <div class="couple-modal-title">情侣空间设置</div>
                <label class="couple-field"><span>空间背景 URL</span><input id="couple-bg-url" class="couple-input" placeholder="留空使用默认背景"></label>
                <label class="couple-field"><span>顶部卡片背景 URL</span><input id="couple-card-url" class="couple-input" placeholder="留空使用默认卡片"></label>
                <div class="couple-file-actions"><button class="couple-ghost-btn" id="couple-bg-file-btn" type="button">上传背景</button><button class="couple-ghost-btn" id="couple-card-file-btn" type="button">上传卡片图</button></div>
                <input type="file" id="couple-bg-file" class="couple-hidden-file" accept="image/*">
                <input type="file" id="couple-card-file" class="couple-hidden-file" accept="image/*">
                <div class="couple-danger-zone">
                    <button class="couple-ghost-btn danger" id="couple-clear-data-btn" type="button">清空记录</button>
                    <button class="couple-ghost-btn danger" id="couple-breakup-btn" type="button">解除关系</button>
                </div>
                <div class="couple-modal-actions"><button class="couple-ghost-btn" id="couple-settings-cancel" type="button">取消</button><button class="couple-primary-btn" id="couple-settings-save" type="button">保存设置</button></div>
            </div>
        </div>

        <div id="couple-preview-modal" class="couple-modal" aria-hidden="true">
            <div class="couple-preview-card">
                <button class="couple-preview-close" id="couple-preview-close" type="button">×</button>
                <img id="couple-preview-img" alt="照片预览">
                <div id="couple-preview-caption" class="couple-preview-caption"></div>
            </div>
        </div>
    </div>









