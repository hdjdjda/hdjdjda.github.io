    <div id="twitter-compose-modal" class="twitter-modal" aria-hidden="true">
        <div class="twitter-modal-card">
            <div class="twitter-modal-header"><button class="twitter-icon-btn" id="twitter-compose-close" aria-label="关闭"><svg viewBox="0 0 24 24"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg></button><div class="twitter-modal-title">新推文</div><button class="twitter-post-btn" id="twitter-compose-send">发布</button></div>
            <div class="twitter-modal-body">
                <div class="twitter-compose-area"><img class="twitter-avatar" id="twitter-compose-avatar" alt="avatar"><div><textarea id="twitter-compose-text" class="twitter-compose-textarea" placeholder="有什么新鲜事？"></textarea><div class="twitter-image-preview" id="twitter-image-preview"><img id="twitter-image-preview-img" alt="preview"><button class="twitter-remove-image" id="twitter-remove-image" type="button">×</button></div></div></div>
                <div class="twitter-compose-tools"><div class="twitter-tool-row"><button class="twitter-tool-btn" id="twitter-image-url-btn" type="button" aria-label="图片 URL"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"></rect><circle cx="8.5" cy="10" r="1.5"></circle><path d="M21 16l-5-5-11 8"></path></svg></button><button class="twitter-tool-btn" id="twitter-image-file-btn" type="button" aria-label="本地图片"><svg viewBox="0 0 24 24"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg></button></div><span id="twitter-compose-count" style="color:#536471;font-size:12px;font-weight:800;">0/280</span></div>
                <input type="file" id="twitter-image-file-input" class="hidden-file-input" accept="image/*">
            </div>
        </div>
    </div>

    <div id="twitter-detail-modal" class="twitter-modal twitter-detail-modal" aria-hidden="true">
        <div class="twitter-modal-card">
            <div class="twitter-modal-header"><button class="twitter-icon-btn" id="twitter-detail-close" aria-label="关闭"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button><div class="twitter-modal-title">推文</div><span style="width:42px"></span></div>
            <div class="twitter-detail-list" id="twitter-detail-list"></div>
            <div class="twitter-reply-box"><img class="twitter-avatar small" id="twitter-reply-avatar" alt="avatar"><div><textarea class="twitter-reply-input" id="twitter-reply-input" placeholder="发布你的回复"></textarea><button class="twitter-reply-send" id="twitter-reply-send">回复</button></div></div>
        </div>
    </div>

    <div id="twitter-settings-modal" class="twitter-modal" aria-hidden="true">
        <div class="twitter-modal-card">
            <div class="twitter-modal-header"><button class="twitter-icon-btn" id="twitter-settings-close" aria-label="关闭"><svg viewBox="0 0 24 24"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg></button><div class="twitter-modal-title">推特设置</div><span style="width:42px"></span></div>
            <div class="twitter-modal-body twitter-settings-grid">
                <label>显示名<input id="twitter-setting-name" placeholder="你的昵称"></label>
                <label>用户名 / Handle<input id="twitter-setting-handle" placeholder="@username"></label>
                <label>个人简介<textarea id="twitter-setting-bio" placeholder="简介"></textarea></label>
                <label>我的页面背景图 URL<input id="twitter-setting-cover" placeholder="https://... 或留空使用默认渐变"></label>
                <div class="twitter-cover-preview" id="twitter-cover-preview"></div>
                <div class="twitter-setting-row"><button class="twitter-lite-btn" id="twitter-cover-file-btn" type="button">选择本地背景图</button><button class="twitter-lite-btn" id="twitter-cover-reset-btn" type="button">恢复默认背景</button></div>
                <input type="file" id="twitter-cover-file-input" class="hidden-file-input" accept="image/*">
                <label>推特世界观 / 时间线设定<textarea id="twitter-setting-worldview" placeholder="告诉模型这个推特世界是什么氛围、哪些 char、user、NPC 会发什么内容"></textarea></label>
                <label>推特 NPC 池<textarea id="twitter-setting-npcs" placeholder="每行一个 NPC：昵称｜@handle｜人设/常发内容方向｜头像URL(可空)"></textarea></label>
                <div class="twitter-setting-row"><button class="twitter-lite-btn" id="twitter-npc-default-btn" type="button">恢复默认 NPC</button><button class="twitter-lite-btn" id="twitter-npc-append-btn" type="button">补充默认 NPC</button></div>
                <div class="twitter-npc-hint">刷新时间线时会从 user、char、NPC 三类账号里混合生成推文；NPC 不依赖通讯录，也会参与评论/热搜氛围。</div>
                <button class="twitter-save-settings" id="twitter-save-settings">保存设置</button>
                <button class="twitter-save-settings" id="twitter-reset-feed" style="background:#eff3f4;color:#0f1419;">清空并重建时间线</button>
            </div>
        </div>
    </div>


    <!-- 聊天应用：桌面聊天图标入口 -->
    <div id="chat-app-page" class="settings-page-overlay chat-page-overlay">
        <div id="chat-view-messages" class="chat-view active">
            <div class="chat-app-header">
                <button class="chat-icon-btn" id="chat-close-btn" title="返回" aria-label="返回">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <span class="chat-app-title">消息</span>
                <button class="chat-icon-btn" id="chat-add-thread-btn" title="添加" aria-label="添加">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </button>
            </div>
            <div id="chat-add-panel" class="chat-add-panel">
                <button id="chat-add-friend-option" class="chat-add-option" type="button"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="16" y1="11" x2="22" y2="11"></line></svg><span>添加好友</span></button>
                <button id="chat-create-group-option" class="chat-add-option" type="button"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg><span>发起群聊</span></button>
            </div>
            <div id="chat-group-tabs" class="chat-group-tabs"></div>
            <div class="chat-list" id="chat-thread-list"></div>
        </div>

        <div id="chat-view-moments" class="chat-view moments-view">
            <div class="moments-hero" id="moments-hero">
                <div class="moments-float-left">
                    <button class="moments-plain-btn" id="moments-back-btn" title="返回消息" aria-label="返回消息">
                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    </button>
                </div>
                <div class="moments-float-right">
                    <button class="moments-plain-btn" id="moments-refresh-btn" title="刷新" aria-label="刷新">
                        <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"></path><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"></path></svg>
                    </button>
                    <button class="moments-plain-btn" id="moments-camera-btn" title="相机" aria-label="相机">
                        <svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                    </button>
                </div>
                <div class="moments-hero-name" id="moments-nickname">昵称</div>
            </div>
            <div class="moments-profile-wrap">
                <div class="moments-profile-line">
                    <div class="moments-avatar-box"><img id="moments-avatar-img" src="https://picsum.photos/id/1025/180/140" alt="头像"></div>
                </div>
                <div class="moments-signature" id="moments-signature">个性签名</div>
            </div>
            <div class="moments-feed" id="moments-feed"></div>
            <input type="file" id="moments-cover-file" class="chat-hidden-file" accept="image/*">
            <input type="file" id="moments-avatar-file" class="chat-hidden-file" accept="image/*">
        </div>

        <div id="chat-view-home" class="chat-view">
            <div class="chat-home-scroll">
                <div class="chat-home-avatar" id="chat-home-avatar-box"><img id="chat-home-avatar-img" src="https://picsum.photos/id/1025/500/360" alt="头像"></div>
                <div class="chat-home-name" id="chat-home-name">昵称</div>
                <div class="chat-home-sign" id="chat-home-sign">个性签名</div>
                <input type="file" id="chat-home-avatar-file" class="chat-hidden-file" accept="image/*">
                <div class="chat-home-actions">
                    <button class="chat-home-action" data-feature="资产钱包"><span class="home-action-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.75 8.75a2.25 2.25 0 0 1 2.25-2.25h8.15c.86 0 1.68.34 2.29.95l1.31 1.3"></path><path d="M4.75 9.75h14.5A1.75 1.75 0 0 1 21 11.5v5.25A2.25 2.25 0 0 1 18.75 19H7a2.25 2.25 0 0 1-2.25-2.25z"></path><path d="M15.75 13.4h5.25"></path><circle cx="16.1" cy="13.4" r=".55" fill="currentColor" stroke="none"></circle></svg></span><span>资产钱包</span><span class="home-action-arrow"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 6.5 15.5 12 10 17.5"></path></svg></span></button>
                    <button class="chat-home-action" data-feature="面具预设"><span class="home-action-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.8 8.3c2.1-1.05 4.36-1.25 6.08-.46.73.34 1.55.34 2.28 0 1.72-.79 3.98-.59 6.08.46"></path><path d="M5.2 8.65c.1 4.8 2.86 8.05 6.8 8.05s6.7-3.25 6.8-8.05"></path><path d="M8.75 10.95c.46-.34 1.04-.34 1.5 0"></path><path d="M13.75 10.95c.46-.34 1.04-.34 1.5 0"></path><path d="M9.25 13.75c1.45.95 4.05.95 5.5 0"></path></svg></span><span>面具预设</span><span class="home-action-arrow"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 6.5 15.5 12 10 17.5"></path></svg></span></button>
                    <button class="chat-home-action" data-feature="表情包库"><span class="home-action-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="5.25" width="14" height="14" rx="4.4"></rect><circle cx="9.6" cy="10.45" r=".52" fill="currentColor" stroke="none"></circle><circle cx="14.4" cy="10.45" r=".52" fill="currentColor" stroke="none"></circle><path d="M8.85 14.1c.88.86 1.9 1.24 3.15 1.24s2.27-.38 3.15-1.24"></path><path d="M8 5.35 6.45 3.95"></path></svg></span><span>表情包库</span><span class="home-action-arrow"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 6.5 15.5 12 10 17.5"></path></svg></span></button>
                    <button class="chat-home-action" data-feature="聊天美化"><span class="home-action-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 7.8A2.8 2.8 0 0 1 7.8 5h7.45a2.8 2.8 0 0 1 2.8 2.8v4.55a2.8 2.8 0 0 1-2.8 2.8H10l-3.75 2.9v-2.9H7.8A2.8 2.8 0 0 1 5 12.35z"></path><path d="M8.2 9.2h6.1"></path><path d="M8.2 11.85h4.05"></path><path d="m17.15 4.35.5 1.1 1.2.13-.9.82.24 1.18-1.04-.6-1.04.6.24-1.18-.9-.82 1.2-.13z"></path></svg></span><span>全局聊天美化</span><span class="home-action-arrow"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 6.5 15.5 12 10 17.5"></path></svg></span></button>
                    <button class="chat-home-action wide" data-feature="全局美化"><span class="home-action-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 4.9 1.55 3.35 3.67.4-2.73 2.48.74 3.61L12 12.87l-3.23 1.87.74-3.61-2.73-2.48 3.67-.4Z"></path><path d="M18.4 6.2v1.95"></path><path d="M17.42 7.17h1.96"></path><path d="M5.8 15.6v1.8"></path><path d="M4.9 16.5h1.8"></path></svg></span><span>全局美化</span><span class="home-action-arrow"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 6.5 15.5 12 10 17.5"></path></svg></span></button>
                </div>
            </div>
        </div>

        <div class="chat-bottom-dock">
            <button class="chat-tab-btn active" data-chat-tab="messages" aria-label="消息"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></button>
            <button class="chat-tab-btn" data-chat-tab="moments" aria-label="朋友圈"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><path d="M12 2v4"></path><path d="M12 18v4"></path><path d="M2 12h4"></path><path d="M18 12h4"></path></svg></button>
            <button class="chat-tab-btn" data-chat-tab="home" aria-label="主页"><svg viewBox="0 0 24 24"><path d="M3 11l9-8 9 8"></path><path d="M5 10v10h14V10"></path><path d="M9 20v-6h6v6"></path></svg></button>
        </div>
    </div>

    <div id="chat-sticker-page" class="chat-feature-page" aria-label="表情包库">
        <div class="chat-feature-header">
            <button id="chat-sticker-back" class="chat-feature-icon-btn" type="button" aria-label="返回"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <div class="chat-feature-title">表情包库</div>
            <div class="chat-feature-actions">
                <button id="chat-sticker-add" class="chat-feature-icon-btn" type="button" aria-label="添加表情包"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg></button>
                <button id="chat-sticker-multi" class="chat-feature-icon-btn" type="button" aria-label="多选"><svg viewBox="0 0 24 24"><rect x="4" y="5" width="6" height="6" rx="1.5"></rect><rect x="14" y="5" width="6" height="6" rx="1.5"></rect><rect x="4" y="15" width="6" height="6" rx="1.5"></rect><path d="m14 18 2 2 4-5"></path></svg></button>
            </div>
        </div>
        <div id="chat-sticker-tabs" class="chat-group-tabs sticker-group-tabs"></div>
        <div id="chat-sticker-content" class="chat-feature-content">
            <div id="chat-sticker-grid" class="sticker-grid"></div>
            <div id="chat-sticker-empty" class="sticker-empty">暂无表情包<br>点击右上角 + 批量添加 URL 和描述</div>
        </div>
        <div id="chat-sticker-bulk-actions" class="sticker-bottom-actions">
            <button id="chat-sticker-move-selected" class="action-btn primary" type="button">移动分组</button>
            <button id="chat-sticker-delete-selected" class="action-btn danger" type="button">删除选中</button>
            <button id="chat-sticker-cancel-multi" class="action-btn" type="button">取消多选</button>
        </div>
    </div>

    <div id="chat-beauty-page" class="chat-feature-page" aria-label="聊天美化">
        <div class="chat-feature-header">
            <button id="chat-beauty-back" class="chat-feature-icon-btn" type="button" aria-label="返回"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <div class="chat-feature-title">聊天美化</div>
            <button id="chat-beauty-save" class="chat-feature-icon-btn" type="button" aria-label="保存"><svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><path d="M17 21v-8H7v8"></path><path d="M7 3v5h8"></path></svg></button>
        </div>
        <div class="chat-feature-content">
            <div class="beauty-scope-card" id="beauty-scope-card">当前：全局聊天美化</div>
            <div class="beauty-preview" id="chat-beauty-preview"></div>
            <div class="beauty-form-grid">
                <div class="beauty-range-row"><label>头像尺寸 <b id="beauty-avatar-size-val">35px</b></label><input id="beauty-avatar-size" type="range" min="24" max="72" value="35"></div>
                <div class="beauty-range-row"><label>头像圆角 <b id="beauty-avatar-radius-val">12px</b></label><input id="beauty-avatar-radius" type="range" min="0" max="36" value="12"></div>
                <div class="beauty-range-row"><label>气泡文字 <b id="beauty-font-size-val">14px</b></label><input id="beauty-font-size" type="range" min="11" max="24" value="14"></div>
                <div class="beauty-range-row"><label>气泡圆角 <b id="beauty-bubble-radius-val">18px</b></label><input id="beauty-bubble-radius" type="range" min="4" max="32" value="18"></div>
                <div class="beauty-range-row"><label>气泡宽度 <b id="beauty-bubble-width-val">62vw</b></label><input id="beauty-bubble-width" type="range" min="48" max="82" value="62"></div>
                <div class="beauty-range-row"><label>消息间距 <b id="beauty-message-gap-val">6px</b></label><input id="beauty-message-gap" type="range" min="0" max="20" value="6"></div>
                <div class="beauty-color-row"><span>user 气泡颜色</span><input id="beauty-user-bubble" type="color" value="#929292"></div>
                <div class="beauty-color-row"><span>char 气泡颜色</span><input id="beauty-ai-bubble" type="color" value="#ffffff"></div>
                <div class="beauty-color-row"><span>user 文字颜色</span><input id="beauty-user-text" type="color" value="#ffffff"></div>
                <div class="beauty-color-row"><span>char 文字颜色</span><input id="beauty-ai-text" type="color" value="#000000"></div>
            </div>
            <div class="Tutuwan-settings-section" style="margin-top:14px;">
                <label class="Tutuwan-settings-label">聊天背景</label>
                <input id="beauty-chat-bg" class="Tutuwan-settings-input" placeholder="图片 / GIF URL，或上传本地文件">
                <div class="beauty-css-actions"><button id="beauty-chat-bg-file-btn" class="action-btn" type="button">上传背景</button><button id="beauty-chat-bg-clear" class="action-btn danger" type="button">清除背景</button></div>
                <input id="beauty-chat-bg-file" class="theme-hidden-file" type="file" accept="image/gif,image/webp,image/*">
            </div>
            <div class="Tutuwan-settings-section" style="margin-top:14px;">
                <label class="Tutuwan-settings-label">头像框 CSS（支持 png/gif 边框思路：outline / box-shadow / background-image）</label>
                <input id="beauty-user-frame" class="Tutuwan-settings-input" placeholder="user头像框，如：3px solid #ff9abb">
                <input id="beauty-ai-frame" class="Tutuwan-settings-input" style="margin-top:8px;" placeholder="char头像框，如：3px solid #9bd8ff">
                <input id="beauty-user-frame-img" class="Tutuwan-settings-input" style="margin-top:8px;" placeholder="user头像框图片 URL（png/gif）">
                <input id="beauty-ai-frame-img" class="Tutuwan-settings-input" style="margin-top:8px;" placeholder="char头像框图片 URL（png/gif）">
                <div class="beauty-css-actions"><button id="beauty-user-frame-file-btn" class="action-btn" type="button">上传user头像框</button><button id="beauty-ai-frame-file-btn" class="action-btn" type="button">上传char头像框</button></div>
                <input id="beauty-user-frame-file" class="theme-hidden-file" type="file" accept="image/png,image/gif,image/webp,image/*">
                <input id="beauty-ai-frame-file" class="theme-hidden-file" type="file" accept="image/png,image/gif,image/webp,image/*">
                <div class="beauty-frame-grid">
                    <div class="beauty-range-row"><label>user框缩放 <b id="beauty-user-frame-scale-val">135%</b></label><input id="beauty-user-frame-scale" type="range" min="50" max="220" value="135"></div>
                    <div class="beauty-range-row"><label>char框缩放 <b id="beauty-ai-frame-scale-val">135%</b></label><input id="beauty-ai-frame-scale" type="range" min="50" max="220" value="135"></div>
                    <div class="beauty-range-row"><label>user框X <b id="beauty-user-frame-x-val">0px</b></label><input id="beauty-user-frame-x" type="range" min="-36" max="36" value="0"></div>
                    <div class="beauty-range-row"><label>char框X <b id="beauty-ai-frame-x-val">0px</b></label><input id="beauty-ai-frame-x" type="range" min="-36" max="36" value="0"></div>
                    <div class="beauty-range-row"><label>user框Y <b id="beauty-user-frame-y-val">0px</b></label><input id="beauty-user-frame-y" type="range" min="-36" max="36" value="0"></div>
                    <div class="beauty-range-row"><label>char框Y <b id="beauty-ai-frame-y-val">0px</b></label><input id="beauty-ai-frame-y" type="range" min="-36" max="36" value="0"></div>
                </div>
            </div>
            <div class="Tutuwan-settings-section">
                <label class="Tutuwan-settings-label">美化预设</label>
                <select id="beauty-preset-select" class="Tutuwan-settings-input"><option value="">选择已保存预设</option></select>
                <div class="beauty-css-actions"><button id="beauty-preset-save" class="action-btn primary" type="button">保存为预设</button><button id="beauty-preset-delete" class="action-btn danger" type="button">删除预设</button></div>
                <button id="beauty-clear-specific" class="action-btn danger" type="button" style="display:none;margin-top:10px;">清除当前 char 专属美化，恢复跟随全局</button>
            </div>
            <div class="Tutuwan-settings-section">
                <label class="Tutuwan-settings-label">原 CSS 模板（可复制修改）</label>
                <textarea id="beauty-base-css" class="Tutuwan-css-textarea" readonly></textarea>
                <div class="beauty-css-actions"><button id="beauty-copy-template" class="action-btn" type="button">复制模板</button><button id="beauty-reset-css" class="action-btn danger" type="button">重置CSS</button></div>
            </div>
            <div class="Tutuwan-settings-section">
                <label class="Tutuwan-settings-label">开发者模式：气泡 CSS（覆盖模板）</label>
                <textarea id="beauty-bubble-css" class="Tutuwan-css-textarea" placeholder="写入 .Tutuwan.user .content / .Tutuwan.ai .content 等规则，保存后覆盖原CSS"></textarea>
                <div class="beauty-css-actions"><button id="beauty-bubble-css-file-btn" class="action-btn" type="button">上传气泡CSS</button><button id="beauty-bubble-css-clear" class="action-btn danger" type="button">清空气泡CSS</button></div>
                <input id="beauty-bubble-css-file" class="theme-hidden-file" type="file" accept=".css,text/css">
            </div>
            <div class="Tutuwan-settings-section">
                <label class="Tutuwan-settings-label">开发者模式：全局 CSS（最后注入，优先级最高）</label>
                <textarea id="beauty-global-css" class="Tutuwan-css-textarea" placeholder="写入任意聊天页面相关 CSS，保存后最后注入，覆盖前面所有CSS"></textarea>
                <div class="beauty-css-actions"><button id="beauty-global-css-file-btn" class="action-btn" type="button">上传全局CSS</button><button id="beauty-global-css-clear" class="action-btn danger" type="button">清空全局CSS</button></div>
                <input id="beauty-global-css-file" class="theme-hidden-file" type="file" accept=".css,text/css">
            </div>
        </div>
    </div>

    <div id="chat-sticker-modal" class="chat-modal-mask" aria-label="添加表情包弹窗">
        <div class="chat-modal-card">
            <div class="chat-modal-title">批量添加表情包</div>
            <div class="chat-modal-help">每行一个，兼容：URL：描述 / URL 描述 / 描述：URL / 描述 URL。会自动识别 http(s)、data:image、blob URL。</div>
            <textarea id="chat-sticker-input" class="chat-modal-textarea" placeholder="https://example.com/a.gif 开心兔兔\nhttps://example.com/b.png：摸头\n晚安：https://example.com/c.webp\n撒花 https://example.com/d.gif"></textarea>
            <div class="chat-modal-actions"><button id="chat-sticker-cancel" class="action-btn" type="button">取消</button><button id="chat-sticker-confirm" class="action-btn primary" type="button">添加</button></div>
        </div>
    </div>

    <div id="chat-thoughts-page" class="chat-feature-page chat-secret-page" aria-label="心声">
        <div class="chat-feature-header">
            <button id="chat-thoughts-back" class="chat-feature-icon-btn" type="button" aria-label="返回"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <div class="chat-feature-title">心声</div>
            <div class="chat-feature-actions">
                <button id="chat-thoughts-clear" class="chat-feature-icon-btn" type="button" aria-label="清空心声"><svg viewBox="0 0 24 24"><path d="M4 7h16"></path><path d="M9 7V4h6v3"></path><path d="M7 7l1 13h8l1-13"></path><path d="M10 11v5"></path><path d="M14 11v5"></path></svg></button>
                <button id="chat-thoughts-generate" class="chat-feature-icon-btn" type="button" aria-label="刷新心声"><svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.5 9a9 9 0 0 1 14.9-3.4L23 10"></path><path d="M20.5 15a9 9 0 0 1-14.9 3.4L1 14"></path></svg></button>
            </div>
        </div>
        <div class="chat-secret-hero">
            <div class="chat-secret-kicker">Inner Voice</div>
            <div id="chat-thoughts-hero-title" class="chat-secret-hero-title">TA 此刻没说出口的话</div>
            <div id="chat-thoughts-hero-sub" class="chat-secret-hero-sub">会根据当前聊天、人设、世界书与共同记忆生成。</div>
        </div>
        <div id="chat-thoughts-list" class="chat-feature-content chat-secret-list"></div>
    </div>

    <div id="chat-diary-page" class="chat-feature-page chat-secret-page" aria-label="日记">
        <div class="chat-feature-header">
            <button id="chat-diary-back" class="chat-feature-icon-btn" type="button" aria-label="返回"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <div class="chat-feature-title">日记</div>
            <div class="chat-feature-actions">
                <button id="chat-diary-clear" class="chat-feature-icon-btn" type="button" aria-label="清空日记"><svg viewBox="0 0 24 24"><path d="M4 7h16"></path><path d="M9 7V4h6v3"></path><path d="M7 7l1 13h8l1-13"></path><path d="M10 11v5"></path><path d="M14 11v5"></path></svg></button>
                <button id="chat-diary-generate" class="chat-feature-icon-btn" type="button" aria-label="刷新日记"><svg viewBox="0 0 24 24"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg></button>
            </div>
        </div>
        <div class="chat-secret-hero diary">
            <div class="chat-secret-kicker">Private Diary</div>
            <div id="chat-diary-hero-title" class="chat-secret-hero-title">TA 的私密日记本</div>
            <div id="chat-diary-hero-sub" class="chat-secret-hero-sub">点击右上角新增，或按聊天需要记录。</div>
        </div>
        <div id="chat-diary-list" class="chat-feature-content chat-secret-list diary-list"></div>
    </div>

    <div id="chat-diary-detail-modal" class="chat-modal-mask" aria-label="日记详情">
        <div class="chat-modal-card chat-diary-paper-card">
            <div class="chat-diary-paper-head">
                <div><span id="chat-diary-detail-day">--</span><small id="chat-diary-detail-month">MONTH</small></div>
                <button id="chat-diary-detail-close" class="chat-feature-icon-btn" type="button" aria-label="关闭"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </div>
            <div id="chat-diary-detail-title" class="chat-diary-paper-title">日记标题</div>
            <div id="chat-diary-detail-meta" class="chat-diary-paper-meta">Mood / Location</div>
            <div id="chat-diary-detail-content" class="chat-diary-paper-content"></div>
            <div class="chat-modal-actions"><button id="chat-diary-detail-delete" class="action-btn danger" type="button">删除</button><button id="chat-diary-detail-ok" class="action-btn primary" type="button">收起</button></div>
        </div>
    </div>




    <div id="Tutuwan-chat-room" class="Tutuwan-chat-room" aria-label="聊天页面">
        <div class="Tutuwan-room-header">
            <button id="Tutuwan-room-back" class="Tutuwan-room-back" type="button" aria-label="返回消息列表"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <div class="Tutuwan-room-title-wrap">
                <span id="Tutuwan-room-title" class="Tutuwan-room-title Tutuwan-title-thought-trigger" role="button" tabindex="0" title="点击查看心声">聊天</span>
                <span id="Tutuwan-room-subtitle" class="Tutuwan-room-subtitle"></span>
            </div>
            <button id="Tutuwan-room-more" class="Tutuwan-room-more" type="button" aria-label="聊天设置"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="1.4"></circle><circle cx="19" cy="12" r="1.4"></circle><circle cx="5" cy="12" r="1.4"></circle></svg></button>
        </div>
        <div id="Tutuwan-room-content" class="Tutuwan-room-content"></div>
        <div id="Tutuwan-tools-panel" class="Tutuwan-tools-panel">
            <button id="Tutuwan-tool-camera" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><path d="M4 7h3l2-2h6l2 2h3v12H4z"></path><circle cx="12" cy="13" r="3.5"></circle></svg></span><span>相机</span></button>
            <button id="Tutuwan-tool-image" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg></span><span>图片</span></button>
            <button id="Tutuwan-tool-redpacket" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><path d="M4 7h16v13H4z"></path><path d="M4 7l8 6 8-6"></path><path d="M12 13v5"></path></svg></span><span>红包</span></button>
            <button id="Tutuwan-tool-transfer" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="3"></rect><path d="M7 10h6"></path><path d="M7 14h10"></path></svg></span><span>转账</span></button>
            <button id="Tutuwan-tool-location" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11z"></path><circle cx="12" cy="10" r="2.3"></circle></svg></span><span>定位</span></button>
            <button id="Tutuwan-tool-phone" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6.4 6.4l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6A2 2 0 0 1 22 16.9z"></path></svg></span><span>电话</span></button>
            <button id="Tutuwan-tool-video" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><rect x="3" y="6" width="13" height="12" rx="2"></rect><path d="M16 10l5-3v10l-5-3z"></path></svg></span><span>视频</span></button>
            <button id="Tutuwan-tool-voice" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><path d="M12 15.6a3.6 3.6 0 0 0 3.6-3.6V6.8a3.6 3.6 0 1 0-7.2 0V12a3.6 3.6 0 0 0 3.6 3.6Z"></path><path d="M5.8 11.7a6.2 6.2 0 0 0 12.4 0"></path><path d="M12 18v3"></path><path d="M9 21h6"></path></svg></span><span>语音</span></button>
            <button id="Tutuwan-tool-listen" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg></span><span>一起听</span></button>
            <button id="Tutuwan-tool-diary" class="Tutuwan-tool-item" type="button"><span class="Tutuwan-tool-icon"><svg viewBox="0 0 24 24"><path d="M6 3.8h9.2L19 7.6v12.6H6z"></path><path d="M15.2 3.8v4H19"></path><path d="M8.6 11h6.8"></path><path d="M8.6 14h6.8"></path><path d="M8.6 17h4.2"></path></svg></span><span>日记</span></button>
        </div>
        <div id="Tutuwan-quote-compose" class="Tutuwan-quote-compose">
            <div id="Tutuwan-quote-compose-name" class="Tutuwan-quote-compose-name"></div>
            <div id="Tutuwan-quote-compose-text" class="Tutuwan-quote-compose-text"></div>
            <button id="Tutuwan-quote-compose-close" class="Tutuwan-quote-compose-close" type="button" aria-label="取消引用">×</button>
        </div>
        <div id="Tutuwan-msg-multi-bar" class="Tutuwan-msg-multi-bar">
            <button id="Tutuwan-multi-delete" class="danger" type="button">删除选中</button>
            <button id="Tutuwan-multi-cancel" type="button">取消多选</button>
        </div>
        <div id="Tutuwan-sticker-panel" class="Tutuwan-sticker-float-panel" aria-label="聊天表情包面板">
            <div id="Tutuwan-sticker-panel-tabs" class="Tutuwan-sticker-panel-tabs"></div>
            <div class="Tutuwan-sticker-panel-body">
                <div id="Tutuwan-sticker-panel-grid" class="Tutuwan-sticker-panel-grid"></div>
                <div id="Tutuwan-sticker-panel-empty" class="Tutuwan-sticker-panel-empty">暂无表情包<br>可到表情包库添加</div>
            </div>
        </div>
        <div class="Tutuwan-room-footer">
            <button id="Tutuwan-plus-btn" class="Tutuwan-footer-btn" type="button" aria-label="更多功能"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg></button>
            <textarea id="Tutuwan-msg-input" class="Tutuwan-msg-input" rows="1" placeholder="输入消息"></textarea>
            <button id="Tutuwan-sticker-toggle" class="Tutuwan-sticker-btn footer-btn-side" type="button" aria-label="表情包"><svg class="Tutuwan-sticker-redraw-icon" viewBox="0 0 24 24" aria-hidden="true"><path class="sticker-back" d="M5.8 6.1h8.4a3.7 3.7 0 0 1 3.7 3.7v8.4a3.1 3.1 0 0 1-3.1 3.1H6.7a4 4 0 0 1-4-4V9.2a3.1 3.1 0 0 1 3.1-3.1Z"></path><path class="sticker-front" d="M8.2 2.7h7.45c.82 0 1.61.33 2.19.91l2.55 2.55c.58.58.91 1.37.91 2.19v7.45a3.5 3.5 0 0 1-3.5 3.5H8.2a3.5 3.5 0 0 1-3.5-3.5V6.2a3.5 3.5 0 0 1 3.5-3.5Z"></path><path class="sticker-corner" d="M15.35 3.05v3.38c0 1.23 1 2.22 2.22 2.22h3.38"></path><path class="sticker-spark" d="M11.9 8.2l1.05 2.3 2.3 1.05-2.3 1.05-1.05 2.3-1.05-2.3-2.3-1.05 2.3-1.05 1.05-2.3Z"></path><circle class="sticker-dot" cx="16.85" cy="14.65" r="1.15"></circle></svg></button>
            <div id="Tutuwan-send-btn" class="Tutuwan-send-btn footer-btn-side send-btn" role="button" tabindex="0" aria-label="发送"><i class="fas fa-paper-plane" aria-hidden="true"></i></div>
        </div>
        <input id="Tutuwan-image-file" class="Tutuwan-hidden-file" type="file" accept="image/*">
        <input id="Tutuwan-camera-file" class="Tutuwan-hidden-file" type="file" accept="image/*" capture="environment">
    </div>



    <div id="Tutuwan-chat-settings" class="Tutuwan-settings-page" aria-label="聊天设置">
        <div class="Tutuwan-settings-header">
            <button id="Tutuwan-settings-back" class="Tutuwan-settings-back" type="button" aria-label="返回聊天"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <div class="Tutuwan-settings-title">聊天设置</div>
            <div></div>
        </div>
        <div class="Tutuwan-settings-content">
            <div class="Tutuwan-avatar-duo">
                <div id="Tutuwan-setting-user-avatar-card" class="Tutuwan-setting-avatar-card">
                    <img id="Tutuwan-setting-user-avatar" src="" alt="user头像">
                    <span id="Tutuwan-setting-user-name">user</span>
                </div>
                <div id="Tutuwan-setting-char-avatar-card" class="Tutuwan-setting-avatar-card">
                    <img id="Tutuwan-setting-char-avatar" src="" alt="char头像">
                    <span id="Tutuwan-setting-char-name">char</span>
                </div>
            </div>
            <div class="Tutuwan-settings-section">
                <label class="Tutuwan-settings-label" for="Tutuwan-remark-input">备注</label>
                <input id="Tutuwan-remark-input" class="Tutuwan-settings-input" type="text" placeholder="添加备注后优先展示备注">
                <div class="Tutuwan-settings-actions" style="margin-top:10px;"><button id="Tutuwan-save-remark-btn" class="action-btn primary" type="button">保存备注</button><button id="Tutuwan-clear-remark-btn" class="action-btn" type="button">清空备注</button></div>
            </div>
            <div class="Tutuwan-settings-section">
                <label class="Tutuwan-settings-label" for="Tutuwan-bg-url">更换聊天背景</label>
                <input id="Tutuwan-bg-url" class="Tutuwan-settings-input" type="text" placeholder="图片 URL 或选择本地文件">
                <div class="Tutuwan-settings-actions" style="margin-top:10px;"><button id="Tutuwan-bg-local-btn" class="action-btn" type="button">本地文件</button><button id="Tutuwan-save-bg-btn" class="action-btn primary" type="button">应用背景</button></div>
                <button id="Tutuwan-reset-bg-btn" class="action-btn" type="button" style="margin-top:10px;">重置背景</button>
            </div>
            <div class="Tutuwan-settings-section">
                <div class="Tutuwan-setting-row"><div><span class="Tutuwan-settings-label" style="margin-bottom:2px;">时间感知功能</span><div class="Tutuwan-settings-help">开启后，当前联系人数据会记录允许 char 感知时间。</div></div><div id="Tutuwan-time-aware-toggle" class="Tutuwan-toggle"></div></div>
            </div>
            <div class="Tutuwan-settings-section">
                <div class="Tutuwan-setting-row"><div><span class="Tutuwan-settings-label" style="margin-bottom:2px;">线下模式</span><div class="Tutuwan-settings-help">开启后私聊输出长文本；群聊会进入线下群像剧情，保留成员发言、动作和场景推进。</div></div><div id="Tutuwan-offline-toggle" class="Tutuwan-toggle"></div></div>
                <div id="Tutuwan-offline-panel" class="Tutuwan-offline-panel">
                    <label class="Tutuwan-settings-label" for="Tutuwan-offline-wordcount">展开字数</label>
                    <input id="Tutuwan-offline-wordcount" class="Tutuwan-settings-input" type="number" min="80" step="10" value="500" placeholder="默认 500 字">
                    <label class="Tutuwan-settings-label" for="Tutuwan-offline-perspective" style="margin-top:12px;">输出视角</label>
                    <select id="Tutuwan-offline-perspective" class="Tutuwan-settings-input Tutuwan-perspective-select">
                        <option value="char">char / 群像视角</option>
                        <option value="user">user 视角</option>
                    </select>
                    <label class="Tutuwan-settings-label" for="Tutuwan-offline-style" style="margin-top:12px;">文风输入栏</label>
                    <textarea id="Tutuwan-offline-style" class="Tutuwan-settings-textarea" placeholder="例如：细腻、克制、生活感、心理描写多、对白少……"></textarea>
                    <button id="Tutuwan-save-offline-btn" class="action-btn primary" type="button" style="margin-top:10px;">保存线下模式设置</button>
                </div>
            </div>
            <div class="Tutuwan-settings-section">
                <div class="Tutuwan-setting-row"><div><span class="Tutuwan-settings-label" style="margin-bottom:2px;">自动总结开关</span><div class="Tutuwan-settings-help">开启后达到阈值自动生成一条历史总结。</div></div><div id="Tutuwan-auto-summary-toggle" class="Tutuwan-toggle"></div></div>
                <div id="Tutuwan-threshold-panel" class="Tutuwan-threshold-panel">
                    <label class="Tutuwan-settings-label" for="Tutuwan-summary-threshold">展开总结阈值</label>
                    <input id="Tutuwan-summary-threshold" class="Tutuwan-settings-input" type="number" min="2" step="1" placeholder="例如 20">
                    <button id="Tutuwan-save-summary-btn" class="action-btn primary" type="button" style="margin-top:10px;">保存总结设置</button>
                </div>
                <div class="Tutuwan-settings-label" style="margin-top:14px;">历史总结列表</div>
                <div id="Tutuwan-summary-list" class="Tutuwan-summary-list"></div>
            </div>
            <div class="Tutuwan-settings-section">
                <button id="Tutuwan-open-beauty-btn" class="action-btn primary" type="button">专属聊天美化</button>
                <div class="Tutuwan-settings-help" style="margin-top:8px;">这里只修改当前 char / 群聊的聊天外观，不影响其它联系人。我的页面里的聊天美化仍为所有 char 统一美化。</div>
                <button id="Tutuwan-open-css-btn" class="action-btn" type="button" style="margin-top:10px;">聊天 CSS 页面入口</button>
            </div>
            <div class="Tutuwan-settings-section">
                <div class="Tutuwan-settings-actions"><button id="Tutuwan-block-btn" class="action-btn danger" type="button">拉黑</button><button id="Tutuwan-clear-history-btn" class="action-btn danger" type="button">清空聊天记录</button></div>
            </div>
        </div>
        <input id="Tutuwan-setting-avatar-file" class="Tutuwan-hidden-file" type="file" accept="image/*">
        <input id="Tutuwan-bg-file" class="Tutuwan-hidden-file" type="file" accept="image/*">
    </div>
    <div id="Tutuwan-css-page" class="Tutuwan-css-page" aria-label="聊天 CSS 页面">
        <div class="Tutuwan-css-header">
            <button id="Tutuwan-css-back" class="Tutuwan-css-back" type="button" aria-label="返回设置"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <div class="Tutuwan-css-title">聊天 CSS</div>
            <div></div>
        </div>
        <div class="Tutuwan-css-content">
            <div id="Tutuwan-css-scope" class="Tutuwan-css-note">当前聊天专属 CSS，会覆盖我的页面全局美化，但不影响其它 char。</div>
            <textarea id="Tutuwan-css-textarea" class="Tutuwan-css-textarea" placeholder="写入当前聊天专属 CSS，例如：.Tutuwan.ai .content { font-style: italic; }"></textarea>
            <div class="Tutuwan-css-actions">
                <button id="Tutuwan-css-save" class="action-btn primary" type="button">保存当前聊天 CSS</button>
                <button id="Tutuwan-css-template" class="action-btn" type="button">插入模板</button>
                <button id="Tutuwan-css-clear" class="action-btn danger" type="button">清空 CSS</button>
                <button id="Tutuwan-css-open-beauty" class="action-btn" type="button">打开完整美化</button>
            </div>
            <div class="Tutuwan-css-note">保存后会写入当前 char / 群聊的专属美化，不会修改“我的页面”的全局美化。</div>
        </div>
    </div>

    <div id="chat-wallet-page" class="settings-page-overlay chat-wallet-page">
        <div class="settings-header chat-wallet-header">
            <svg id="close-chat-wallet-btn" class="chat-wallet-close" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2.5">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <span>资产钱包</span>
        </div>
        <div class="settings-content chat-wallet-content">
            <div class="wallet-balance-card">
                <div class="wallet-balance-label">总资产</div>
                <div id="wallet-balance-value" class="wallet-balance-value">¥0.00</div>
                <div class="wallet-balance-desc">支持充值与提现，账单明细会同步记录在下方列表。</div>
                <div class="wallet-balance-actions">
                    <button id="wallet-recharge-btn" class="wallet-action-btn" type="button">充值</button>
                    <button id="wallet-withdraw-btn" class="wallet-action-btn light" type="button">提现</button>
                </div>
            </div>
            <div class="wallet-bill-section">
                <div class="wallet-section-title">账单</div>
                <div id="wallet-bill-list" class="wallet-bill-list"></div>
            </div>
        </div>
    </div>



    <div id="Tutuwan-music-page" class="settings-page-overlay Tutuwan-music-page">
        <div class="settings-header Tutuwan-music-header">
            <svg id="close-Tutuwan-music-btn" class="Tutuwan-music-close" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2.5">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <span>音乐</span>
        </div>
        <div class="settings-content Tutuwan-music-content">
            <div id="Tutuwan-music-cover" class="Tutuwan-music-cover"><i class="fas fa-music" aria-hidden="true"></i></div>
            <div id="Tutuwan-music-title" class="Tutuwan-music-title">夜色心事</div>
            <div id="Tutuwan-music-artist" class="Tutuwan-music-artist">Tutuwan Radio</div>
            <div id="Tutuwan-music-listener" class="Tutuwan-music-listener"></div>
            <div class="Tutuwan-music-progress">
                <div class="Tutuwan-music-track"><div id="Tutuwan-music-fill" class="Tutuwan-music-fill"></div></div>
                <div class="Tutuwan-music-time"><span id="Tutuwan-music-now">00:00</span><span id="Tutuwan-music-total">03:20</span></div>
            </div>
            <div class="Tutuwan-music-controls">
                <button id="Tutuwan-music-prev" class="Tutuwan-music-btn" type="button" aria-label="上一首"><svg viewBox="0 0 24 24"><path d="M19 20 9 12l10-8v16Z"></path><path d="M5 5v14"></path></svg></button>
                <button id="Tutuwan-music-play" class="Tutuwan-music-btn primary" type="button" aria-label="播放"><svg id="Tutuwan-music-play-icon" viewBox="0 0 24 24"><path d="M8 5v14l11-7Z" fill="currentColor" stroke="none"></path></svg></button>
                <button id="Tutuwan-music-next" class="Tutuwan-music-btn" type="button" aria-label="下一首"><svg viewBox="0 0 24 24"><path d="M5 4l10 8-10 8V4Z"></path><path d="M19 5v14"></path></svg></button>
            </div>
            <div class="Tutuwan-music-actions">
                <button id="Tutuwan-music-together" class="Tutuwan-music-action" type="button">一起听</button>
                <button id="Tutuwan-music-share-chat" class="Tutuwan-music-action light" type="button">发到当前聊天</button>
            </div>
        </div>
    </div>

    <div id="chat-mask-page" class="settings-page-overlay chat-mask-page">
        <div class="settings-header chat-mask-header">
            <svg id="close-chat-mask-btn" class="chat-mask-close" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2.5">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <span>面具预设</span>
            <button id="chat-mask-add-btn" class="chat-mask-add-btn" type="button" aria-label="添加面具预设"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg></button>
        </div>
        <div class="settings-content">
            <div id="chat-mask-list" class="chat-mask-list"></div>
        </div>
    </div>

    <!-- 主题应用：底部 Dock 第三个图标入口 -->
    <div id="theme-page" class="settings-page-overlay theme-page-overlay">
        <div class="settings-header">
            <svg id="close-theme-btn" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2.5" style="margin-right: 12px; cursor: pointer;">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <span>主题应用</span>
        </div>
        <div class="settings-content">
            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="3"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg>
                    更换壁纸
                </h4>
                <p class="theme-section-desc">支持图片、GIF、MP4/WebM 动态壁纸；本地文件会保存到浏览器本地数据中。</p>
                <div id="theme-wallpaper-preview" class="theme-wallpaper-preview">默认壁纸</div>
                <div class="settings-row" style="margin-top: 14px;">
                    <span class="settings-label">壁纸 URL</span>
                    <input type="text" id="theme-wallpaper-url" class="settings-input" placeholder="图片 / GIF / MP4 / WebM URL">
                </div>
                <div class="theme-grid-2">
                    <button class="action-btn" id="theme-wallpaper-file-btn">选择本地壁纸</button>
                    <button class="action-btn primary" id="theme-wallpaper-apply">应用壁纸</button>
                    <button class="action-btn danger" id="theme-wallpaper-reset" style="grid-column: span 2;">重置默认壁纸</button>
                </div>
                <input type="file" id="theme-wallpaper-file" class="theme-hidden-file" accept="image/*,video/mp4,video/webm,video/ogg">
            </div>

            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 6h16v12H4z"></path><path d="M8 10h.01"></path><path d="M4 16l5-5 4 4 3-3 4 4"></path></svg>
                    聊天三页壁纸
                </h4>
                <p class="theme-section-desc">可分别上传消息页、朋友圈页、我的主页壁纸；支持图片与 GIF。</p>
                <div id="theme-chat-wallpaper-grid" class="theme-chat-wallpaper-grid"></div>
            </div>

            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7" rx="2"></rect><rect x="14" y="3" width="7" height="7" rx="2"></rect><rect x="14" y="14" width="7" height="7" rx="2"></rect><rect x="3" y="14" width="7" height="7" rx="2"></rect></svg>
                    更换图标
                </h4>
                <p class="theme-section-desc">每个桌面图标都可单独填 URL 或上传本地图片，并支持独立重置。</p>
                <div id="theme-icon-list" class="theme-icon-list"></div>
            </div>

            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 7V4h16v3"></path><path d="M9 20h6"></path><path d="M12 4v16"></path></svg>
                    全局字体
                </h4>
                <p class="theme-section-desc">支持字体 URL 或本地字体文件；可调字体大小与粗细，点击应用后立即全局生效。</p>
                <div class="settings-row">
                    <span class="settings-label">字体 URL</span>
                    <input type="text" id="theme-font-url" class="settings-input" placeholder=".woff / .woff2 / .ttf / .otf URL">
                </div>
                <div class="theme-grid-2">
                    <button class="action-btn" id="theme-font-file-btn">选择本地字体</button>
                    <button class="action-btn primary" id="theme-font-apply">应用字体</button>
                </div>
                <input type="file" id="theme-font-file" class="theme-hidden-file" accept=".woff,.woff2,.ttf,.otf,font/*">
                <div class="settings-row" style="margin-top: 16px;">
                    <div class="theme-inline-row">
                        <span class="settings-label" style="flex: 1;">字体大小</span>
                        <span id="theme-font-size-display" class="theme-value-pill">16px</span>
                    </div>
                    <input type="range" id="theme-font-size" min="12" max="22" step="1" value="16">
                </div>
                <div class="settings-row">
                    <span class="settings-label">字体粗细</span>
                    <select id="theme-font-weight" class="settings-select">
                        <option value="300">Light 300</option>
                        <option value="400">Regular 400</option>
                        <option value="500">Medium 500</option>
                        <option value="600">SemiBold 600</option>
                        <option value="700">Bold 700</option>
                    </select>
                </div>
                <button class="action-btn danger" id="theme-font-reset">重置默认字体</button>
            </div>

            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6"></path><path d="M9 21H3v-6"></path><path d="M21 3l-7 7"></path><path d="M3 21l7-7"></path></svg>
                    缩放 UI
                </h4>
                <p class="theme-section-desc">一键缩放全局 UI，范围 90% 到 110%，并支持恢复默认比例。</p>
                <div class="theme-inline-row">
                    <span class="settings-label" style="flex: 1;">当前比例</span>
                    <span id="theme-ui-scale-display" class="theme-value-pill">100%</span>
                </div>
                <input type="range" id="theme-ui-scale" min="90" max="110" step="1" value="100">
                <div class="theme-grid-2" style="margin-top: 10px;">
                    <button class="action-btn primary" id="theme-ui-apply">应用缩放</button>
                    <button class="action-btn danger" id="theme-ui-reset">重置默认</button>
                </div>
            </div>

            <div class="settings-section">
                <h4>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M8 3H5a2 2 0 0 0-2 2v3"></path><path d="M16 3h3a2 2 0 0 1 2 2v3"></path><path d="M8 21H5a2 2 0 0 1-2-2v-3"></path><path d="M16 21h3a2 2 0 0 0 2-2v-3"></path></svg>
                    一键全屏
                </h4>
                <p class="theme-section-desc">点击后进入全屏，并隐藏虚拟系统状态栏；再次点击恢复。</p>
                <button class="action-btn primary" id="theme-fullscreen-toggle">一键隐藏系统状态栏</button>
            </div>
        </div>
    </div>


</div>

<!-- 新增：配置与帮助指南弹窗 -->


<div id="chat-mask-modal" class="modal-overlay chat-form-modal">
    <div class="modal-content">
        <h3 id="chat-mask-modal-title">添加面具预设</h3>
        <div class="input-group">
            <div class="chat-avatar-edit-row">
                <div class="chat-avatar-preview"><img id="chat-mask-avatar-preview" src="https://picsum.photos/id/1025/160/160" alt="面具头像"></div>
                <div class="chat-avatar-edit-tools">
                    <input type="text" id="chat-mask-avatar-url-input" placeholder="user 头像图片 URL">
                    <label class="chat-avatar-local-btn">本地文件<input type="file" id="chat-mask-avatar-file" accept="image/*"></label>
                </div>
            </div>
            <input type="text" id="chat-mask-name-input" placeholder="user 姓名">
            <textarea id="chat-mask-setting-input" class="chat-form-textarea" placeholder="user 设定内容"></textarea>
        </div>
        <div class="modal-actions">
            <button id="chat-mask-cancel-btn" class="cancel-btn" type="button">取消</button>
            <button id="chat-mask-save-btn" class="save-btn" type="button">保存</button>
        </div>
        <button id="chat-mask-delete-btn" class="modal-confirm-btn chat-form-danger" type="button" style="display:none;">删除该预设</button>
    </div>
</div>

<div id="chat-friend-modal" class="modal-overlay chat-form-modal">
    <div class="modal-content">
        <h3 id="chat-friend-modal-title">添加好友</h3>
        <div class="input-group">
            <div class="chat-dual-avatar-wrap">
                <div class="chat-avatar-row-title">char 头像</div>
                <div class="chat-avatar-edit-row">
                    <div class="chat-avatar-preview"><img id="chat-friend-avatar-preview" src="https://picsum.photos/seed/new-char/160/160" alt="联系人头像"></div>
                    <div class="chat-avatar-edit-tools">
                        <input type="text" id="chat-friend-avatar-url-input" placeholder="char 头像图片 URL">
                        <label class="chat-avatar-local-btn">本地文件<input type="file" id="chat-friend-avatar-file" accept="image/*"></label>
                    </div>
                </div>
                <div class="chat-avatar-row-title">user 头像 / 面具</div>
                <div class="chat-avatar-edit-row">
                    <div class="chat-avatar-preview"><img id="chat-friend-user-avatar-preview" src="https://picsum.photos/id/1025/160/160" alt="user 头像"></div>
                    <div class="chat-avatar-edit-tools">
                        <input type="text" id="chat-friend-user-avatar-url-input" placeholder="user 头像图片 URL">
                        <label class="chat-avatar-local-btn">本地文件<input type="file" id="chat-friend-user-avatar-file" accept="image/*"></label>
                    </div>
                </div>
                <select id="chat-friend-mask-select" class="chat-form-select"><option value="">不绑定 user 面具预设</option></select>
                <div class="chat-multi-help">可直接编辑 user 信息；选择面具只用于快速带入，不会限制字数。</div>
            </div>
            <input type="text" id="chat-friend-name-input" placeholder="char 姓名">
            <textarea id="chat-friend-setting-input" class="chat-form-textarea" placeholder="char 设定内容"></textarea>
            <input type="text" id="chat-friend-user-name-input" placeholder="user 姓名">
            <textarea id="chat-friend-user-setting-input" class="chat-form-textarea" placeholder="user 设定内容"></textarea>
            <input type="text" id="chat-friend-voice-id-input" class="chat-form-input" placeholder="VOICE ID（char 音色 ID，如 tutumaru_01）">
            <select id="chat-friend-worldbook-select" class="chat-form-select chat-multi-select chat-worldbook-hidden-select" multiple></select>
            <div id="chat-friend-worldbook-picker" class="chat-worldbook-picker">
                <button type="button" id="chat-friend-worldbook-field" class="chat-worldbook-field" aria-expanded="false">
                    <span id="chat-friend-worldbook-summary" class="chat-worldbook-summary chat-worldbook-placeholder">关联世界书（可多选）</span>
                    <svg class="chat-worldbook-arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 10.5 12 15.5 17 10.5"></path></svg>
                </button>
                <div id="chat-friend-worldbook-panel" class="chat-worldbook-panel" aria-label="关联世界书选项"></div>
            </div>
            <div class="chat-multi-help">char 关联世界书可多选；点击上方关联世界书字段即可勾选多个世界书。</div>
            <select id="chat-friend-group-select" class="chat-form-select"></select>
        </div>
        <div class="modal-actions">
            <button id="chat-friend-cancel-btn" class="cancel-btn" type="button">取消</button>
            <button id="chat-friend-save-btn" class="save-btn" type="button">保存</button>
        </div>
    </div>
</div>

<div id="help-modal" class="modal-overlay">
    <div class="modal-content" style="max-width: 340px; padding: 24px 24px 20px;">
        <h3 id="help-title" style="margin-bottom: 12px; color: var(--pink-dark);">使用指南</h3>
        <div id="help-body" style="font-size: 13px; color: var(--gray-text); line-height: 1.6; max-height: 60vh; overflow-y: auto; text-align: justify; padding-right: 4px;">
            <!-- 内容由 JS 动态填入 -->
        </div>
        <button class="save-btn modal-confirm-btn" style="margin-top: 20px;" onclick="closeHelpModal()">我知道了</button>
    </div>
</div>



<!-- 全局页面弹窗：统一替代浏览器弹窗 -->
<div id="global-dialog" class="modal-overlay" aria-hidden="true">
    <div class="modal-content" style="max-width: 330px; padding: 24px 24px 20px;">
        <h3 id="global-dialog-title" style="margin-bottom: 4px; color: var(--pink-dark);">兔兔丸提示</h3>
        <div id="global-dialog-message" class="global-dialog-message"></div>
        <div id="global-dialog-input-wrap" class="input-group" style="display: none; margin-top: 2px;">
            <input type="text" id="global-dialog-input" placeholder="请输入内容...">
        </div>
        <div class="global-dialog-actions">
            <button id="global-dialog-cancel" class="cancel-btn" type="button">取消</button>
            <button id="global-dialog-ok" class="save-btn" type="button">确定</button>
        </div>
    </div>
</div>

<!-- 模型选择弹窗：拉取模型后自动弹出 -->
<div id="model-picker-modal" class="modal-overlay" aria-hidden="true">
    <div class="modal-content model-picker-content">
        <h3 style="margin-bottom: 2px; color: var(--pink-dark);">选择模型</h3>
        <p class="model-picker-subtitle">点击下方模型会自动填入“模型选择”；也可以关闭后直接点击模型输入框手动输入。</p>
        <input type="text" id="model-picker-search" class="model-picker-search" placeholder="搜索模型名...">
        <div id="model-picker-list" class="model-picker-list"></div>
        <div class="modal-actions" style="margin-top: 2px;">
            <button class="cancel-btn" id="model-picker-close" type="button">关闭</button>
        </div>
    </div>
</div>

<!-- 全新精致更换图片与文案弹窗 -->
<div id="image-edit-modal" class="modal-overlay">
    <div class="modal-content">
        <h3 id="modal-title">更换图片</h3>
        
        <!-- 单图输入组 -->
        <div class="input-group" id="single-image-inputs" style="display: none;">
            <input type="text" id="img-url-input" placeholder="图片 URL">
            <div class="file-input-wrapper">
                <button class="file-btn">
                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                    本地文件
                </button>
                <input type="file" id="img-file-input" accept="image/*">
            </div>
        </div>

        <!-- 多图输入组 (针对左侧组件) -->
        <div class="input-group" id="multi-image-inputs" style="display: none; gap: 10px;">
            <div class="multi-img-row">
                <input type="text" id="img-url-input-0" placeholder="图片 URL">
                <div class="file-input-wrapper">
                    <button class="file-btn">本地文件</button>
                    <input type="file" id="img-file-input-0" accept="image/*">
                </div>
            </div>
            <div class="multi-img-row">
                <input type="text" id="img-url-input-1" placeholder="图片 URL">
                <div class="file-input-wrapper">
                    <button class="file-btn">本地文件</button>
                    <input type="file" id="img-file-input-1" accept="image/*">
                </div>
            </div>
            <div class="multi-img-row">
                <input type="text" id="img-url-input-2" placeholder="图片 URL">
                <div class="file-input-wrapper">
                    <button class="file-btn">本地文件</button>
                    <input type="file" id="img-file-input-2" accept="image/*">
                </div>
            </div>
        </div>

        <!-- 纯文案输入组 -->
        <div class="input-group" id="text-inputs" style="display: none;">
            <input type="text" id="text-edit-input" placeholder="输入新文案...">
        </div>

        <div class="modal-actions">
            <button id="modal-cancel-btn" class="cancel-btn">取消</button>
            <button id="modal-save-btn" class="save-btn">确定</button>
        </div>
    </div>
</div>

<script src="./tutuwan-shield.min.js"></script>
<script src="./app.js"></script>


</body>
</html>
