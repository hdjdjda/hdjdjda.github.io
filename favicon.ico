                <div class="shop-list" id="shop-cart-list"></div>
                <div class="shop-cart-footer">
                    <div><div style="font-size:11px;color:var(--shop-muted);font-weight:800;">合计</div><div class="shop-price" id="shop-cart-total"><small>¥</small>0.00</div></div>
                    <button class="shop-ghost-btn" id="shop-daifu-btn">找人代付</button>
